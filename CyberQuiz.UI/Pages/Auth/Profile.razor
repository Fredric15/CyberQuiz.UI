@page "/profile"
@rendermode InteractiveServer
@inject AuthApiClient AuthApiClient
@inject AuthStateService AuthStateService
@inject CategoryApiClient CategoryApiClient
@inject ProgressApiClient ProgressApiClient
@inject NavigationManager NavigationManager

<PageTitle>Profile</PageTitle>

<h1>Profil</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_profile is not null)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">Konto</h5>
            <p class="mb-1"><strong>Användarnamn:</strong> @_profile.UserName</p>
            <p class="mb-2"><strong>Epost:</strong> @_profile.Email</p>
            <p class="mb-1"><strong>Framsteg:</strong> @_generalProgressPercentage%</p>
            <div class="progress" role="progressbar" aria-label="General quiz progression" aria-valuenow="@_generalProgressPercentage" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: @_generalProgressPercentage%;">@_generalProgressPercentage%</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">Ändra Epost</h5>

                    <EditForm Model="_emailModel" OnValidSubmit="HandleEmailUpdateAsync" FormName="profile-email">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="profile-email" class="form-label">Ny Epost</label>
                            <InputText id="profile-email" class="form-control" @bind-Value="_emailModel.Email" autocomplete="email" />
                            <ValidationMessage For="() => _emailModel.Email" class="text-danger" />
                        </div>

                        @if (_emailErrors.Count > 0)
                        {
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    @foreach (var error in _emailErrors)
                                    {
                                        <li>@error</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (_emailSuccessMessage is not null)
                        {
                            <div class="alert alert-success">@_emailSuccessMessage</div>
                        }

                        <button type="submit" class="btn btn-primary" disabled="@_isUpdatingEmail">Updatera Epost</button>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">Ändra Lösenord</h5>

                    <EditForm Model="_passwordModel" OnValidSubmit="HandlePasswordChangeAsync" FormName="profile-password">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="current-password" class="form-label">Nuvarande lösenord</label>
                            <InputText id="current-password" class="form-control" type="password" @bind-Value="_passwordModel.CurrentPassword" autocomplete="current-password" />
                            <ValidationMessage For="() => _passwordModel.CurrentPassword" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label for="new-password" class="form-label">Nytt lösenord</label>
                            <InputText id="new-password" class="form-control" type="password" @bind-Value="_passwordModel.NewPassword" autocomplete="new-password" />
                            <ValidationMessage For="() => _passwordModel.NewPassword" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label for="confirm-password" class="form-label">Bekräfta nytt lösenord</label>
                            <InputText id="confirm-password" class="form-control" type="password" @bind-Value="_passwordModel.ConfirmNewPassword" autocomplete="new-password" />
                            <ValidationMessage For="() => _passwordModel.ConfirmNewPassword" class="text-danger" />
                        </div>

                        @if (_passwordErrors.Count > 0)
                        {
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    @foreach (var error in _passwordErrors)
                                    {
                                        <li>@error</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (_passwordSuccessMessage is not null)
                        {
                            <div class="alert alert-success">@_passwordSuccessMessage</div>
                        }

                        <button type="submit" class="btn btn-primary" disabled="@_isChangingPassword">Updatera lösenord</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private UserProfileModel? _profile;
    private readonly UpdateEmailModel _emailModel = new();
    private ChangePasswordModel _passwordModel = new();
    private bool _loading = true;
    private string? _errorMessage;
    private List<string> _emailErrors = [];
    private List<string> _passwordErrors = [];
    private bool _isUpdatingEmail;
    private bool _isChangingPassword;
    private string? _emailSuccessMessage;
    private string? _passwordSuccessMessage;
    private double _generalProgressPercentage;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var (success, profile, errors) = await AuthApiClient.GetProfileAsync();
            if (!success || profile is null)
            {
                _errorMessage = errors.FirstOrDefault() ?? "Failed to load profile.";
                return;
            }

            _profile = profile;
            _emailModel.Email = profile.Email;
            await LoadGeneralProgressAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadGeneralProgressAsync()
    {
        var categories = (await CategoryApiClient.GetCategoriesWithSubCategories()).ToList();
        var totalSubCategories = categories.SelectMany(c => c.SubCategories).Count();
        if (totalSubCategories == 0)
        {
            _generalProgressPercentage = 0;
            return;
        }

        var progress = (await ProgressApiClient.GetSubCategoryProgressAsync()).ToList();
        var passedCount = progress.Count(p => p.IsPassed);
        _generalProgressPercentage = Math.Round((double)passedCount / totalSubCategories * 100, 2);
    }

    private async Task HandleEmailUpdateAsync()
    {
        _isUpdatingEmail = true;
        _emailErrors = [];
        _emailSuccessMessage = null;

        try
        {
            var (success, profile, errors) = await AuthApiClient.UpdateEmailAsync(_emailModel.Email);
            if (!success || profile is null)
            {
                _emailErrors = errors.ToList();
                return;
            }

            _profile = profile;
            AuthStateService.UpdateProfile(profile.Email, profile.UserName);
            _emailSuccessMessage = "Email updated successfully.";
        }
        finally
        {
            _isUpdatingEmail = false;
        }
    }

    private async Task HandlePasswordChangeAsync()
    {
        _isChangingPassword = true;
        _passwordErrors = [];
        _passwordSuccessMessage = null;

        try
        {
            var (success, errors) = await AuthApiClient.ChangePasswordAsync(_passwordModel.CurrentPassword, _passwordModel.NewPassword);
            if (!success)
            {
                _passwordErrors = errors.ToList();
                return;
            }

            _passwordModel = new ChangePasswordModel();
            _passwordSuccessMessage = "Password updated successfully.";
        }
        finally
        {
            _isChangingPassword = false;
        }
    }
}