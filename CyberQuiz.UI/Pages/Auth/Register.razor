@page "/register"
@using CyberQuiz.UI.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthApiClient AuthApi
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h3 class="mb-4 text-center">Skapa konto</h3>
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@((MarkupString)ErrorMessage)</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input @bind="Email" type="email" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Användarnamn</label>
                        <input @bind="UserName" type="text" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lösenord</label>
                        <input @bind="Password" type="password" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bekräfta lösenord</label>
                        <input @bind="ConfirmPassword" type="password" class="form-control" />
                    </div>
                    <button class="btn btn-success w-100" @onclick="HandleRegister">Registrera</button>
                    <p class="mt-3 mb-0 text-center">
                        Har du redan ett konto?
                        <a href="/" class="ms-1">Logga in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string Email = "";
    private string UserName = "";
    private string Password = "";
    private string ConfirmPassword = "";
    private string? ErrorMessage;

    private async Task HandleRegister()
    {
        // UI-validering
        if (string.IsNullOrWhiteSpace(Email) ||
            string.IsNullOrWhiteSpace(UserName) ||
            string.IsNullOrWhiteSpace(Password) ||
            string.IsNullOrWhiteSpace(ConfirmPassword))
        {
            ErrorMessage = "Fyll i alla fält.";
            return;
        }

        if (Password != ConfirmPassword)
        {
            ErrorMessage = "Lösenorden matchar inte.";
            return;
        }

        // Anropa API:t via AuthApiClient
        var response = await AuthApi.RegisterAsync(UserName, Email, Password);

        if (!response.Success)
        {
            // Visa API-fel
            ErrorMessage = string.Join("<br>", response.Errors);
            return;
        }

        // Spara användaren i AuthStateService
        var customProvider = (CustomAuthStateProvider)AuthProvider;
        await customProvider.MarkUserAsAuthenticated(response.Result!.Token);

        // Navigera vidare
        Nav.NavigateTo("/categories", true);
    }
}