@page "/register"
@using CyberQuiz.UI.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthApiClient AuthApi
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="auth-wrapper">
    <div class="auth-panel">
        <h2 class="auth-title">Skapa konto</h2>
        <p class="auth-subtitle">Börja din resa här</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="auth-error">@((MarkupString)ErrorMessage)</div>
        }

        <div class="auth-field">
            <label>Email</label>
            <input @bind="Email" type="email" />
        </div>

        <div class="auth-field">
            <label>Användarnamn</label>
            <input @bind="UserName" type="text" />
        </div>

        <div class="auth-field">
            <label>Lösenord</label>
            <input @bind="Password" type="password" />
        </div>

        <div class="auth-field">
            <label>Bekräfta lösenord</label>
            <input @bind="ConfirmPassword" type="password" />
        </div>

        <button class="auth-button success" @onclick="HandleRegister">Registrera</button>

        <p class="auth-switch">
            Har du redan ett konto?
            <a href="/">Logga in</a>
        </p>
    </div>
</div>

@code {
    private string Email = "";
    private string UserName = "";
    private string Password = "";
    private string ConfirmPassword = "";
    private string? ErrorMessage;

    private async Task HandleRegister()
    {
        // UI-validering
        if (string.IsNullOrWhiteSpace(Email) ||
            string.IsNullOrWhiteSpace(UserName) ||
            string.IsNullOrWhiteSpace(Password) ||
            string.IsNullOrWhiteSpace(ConfirmPassword))
        {
            ErrorMessage = "Fyll i alla fält.";
            return;
        }

        if (Password != ConfirmPassword)
        {
            ErrorMessage = "Lösenorden matchar inte.";
            return;
        }

        // Anropa API:t via AuthApiClient
        var response = await AuthApi.RegisterAsync(UserName, Email, Password);

        if (!response.Success)
        {
            // Visa API-fel
            ErrorMessage = string.Join("<br>", response.Errors);
            return;
        }

        // Spara användaren i AuthStateService
        var customProvider = (CustomAuthStateProvider)AuthProvider;
        await customProvider.MarkUserAsAuthenticated(response.Result!.Token);

        // Navigera vidare
        Nav.NavigateTo("/", true);
    }
}