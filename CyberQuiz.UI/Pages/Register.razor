@page "/register"
@namespace CyberQuiz.UI.Pages

@inject NavigationManager Nav

<h3>Skapa konto</h3>

<div style="display:flex; flex-direction:column; width:250px; gap:10px;">
    <input @bind="Email" placeholder="Email" />
    <input @bind="Password" type="password" placeholder="Lösenord" />
    <input @bind="ConfirmPassword" type="password" placeholder="Bekräfta lösenord" />

    <button @onclick="RegisterUser">Registrera</button>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <p>@Message</p>
}

@code {
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private string ConfirmPassword { get; set; } = "";
    private string Message { get; set; } = "";

    private void RegisterUser()
    {
        // Dummy-validering
        if (string.IsNullOrWhiteSpace(Email) ||
            string.IsNullOrWhiteSpace(Password) ||
            string.IsNullOrWhiteSpace(ConfirmPassword))
        {
            Message = "Alla fält måste fyllas i.";
            return;
        }

        if (Password != ConfirmPassword)
        {
            Message = "Lösenorden matchar inte.";
            return;
        }

        // Dummy-register
        Message = $"Konto skapat för {Email}";

        // Navigera till login
        Nav.NavigateTo("/");

    }
}