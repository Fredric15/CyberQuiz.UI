@page "/categories"
@using CyberQuiz.UI.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject CategoryApiClient CategoryApi
@inject ProgressApiClient ProgressApi
@rendermode InteractiveServer

<AuthorizeView>
    <Authorizing>
        <p>Loading...</p>
    </Authorizing>
    <Authorized>
        <h1 class="mb-4">Välj kategori</h1>

        <div class="row g-4">
            @foreach (var c in _categories)
            {
                var isUnlocked = IsCategoryUnlocked(c);
                var isCompleted = IsCategoryCompleted(c);

                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <QuizCard Title="@c.Title"
                              Description="@c.Description"
                              OnClick="() => NavigateTo(c.Id)"
                              Unlocked="isUnlocked"
                              Completed="isCompleted" />
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <h1 class="mb-4">Du måste vara inloggad för att se kategorier</h1>
        <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/")'>Logga in</button>
    </NotAuthorized>
</AuthorizeView>
@code {
    private List<CategoryDetailModel> _categories = [];
    private Dictionary<int, SubCategoryProgressModel> _progressBySubCategoryId = [];

    protected override async Task OnInitializedAsync()
    {
        //hämta kategorier från API
        _categories = (await CategoryApi.GetCategoriesWithSubCategories())
                .OrderBy(c => c.Id)
                .ToList();
        var progress = await ProgressApi.GetSubCategoryProgressAsync();
        _progressBySubCategoryId = progress.ToDictionary(p => p.SubCategoryId, p => p);


    }

    private void NavigateTo(int id)
    {
        Navigation.NavigateTo($"/categories/{id}");
    }

    [Inject] NavigationManager Navigation { get; set; } = default!;

    private bool IsCategoryUnlocked(CategoryDetailModel category)
    {
        if (_categories.Count == 0)
            return false;

        var ordered = _categories.OrderBy(c => c.Id).ToList();
        if (ordered[0].Id == category.Id)
            return true;

        var index = ordered.FindIndex(c => c.Id == category.Id);
        if (index <= 0)
            return true;

        return IsCategoryCompleted(ordered[index - 1]);
    }

    private bool IsCategoryCompleted(CategoryDetailModel category)
    {
        var subCategoryIds = category.SubCategories.Select(s => s.Id).ToList();
        if (subCategoryIds.Count == 0)
            return true;

        return subCategoryIds.All(id => _progressBySubCategoryId.TryGetValue(id, out var progress) && progress.IsPassed);
    }
}


