@namespace CyberQuiz.UI.Components.Pages
@page "/"
@inject NavigationManager Nav

<h3>Logga in</h3>

<div style="display:flex; flex-direction:column; width:250px; gap:10px;">
    <input @bind="Email" placeholder="Email" />
    <input @bind="Password" type="password" placeholder="Lösenord" />
    <button @onclick="LoginUser">Logga in</button>
    <button @onclick="GoToRegister">Registrera konto</button>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <p>@Message</p>
}

@code {
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private string Message { get; set; } = "";

    private void LoginUser()
    {
        if (Email == "test@test.com" && Password == "123")
        {
            Nav.NavigateTo("/home");
        }
        else
        {
            Message = "Fel email eller lösenord.";
        }
    }

    private void GoToRegister()
    {
        Nav.NavigateTo("/register");
    }
}
