@inherits LayoutComponentBase
@inject AuthStateService AuthStateService
@inject AuthApiClient AuthApiClient
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage ProtectedLocalStorage
@implements IDisposable

<div class="page">

    <!-- DIN NAVBAR -->
    <nav class="nav-container">
        <div class="nav-left">
            <span class="nav-logo">CyberQuiz</span>
        </div>

        <div class="nav-right">
            @if (AuthStateService.IsAuthenticated)
            {
                <NavLink href="/categories">Kategorier</NavLink>
                <NavLink href="/profile">Mitt konto</NavLink>
                <button class="btn btn-link nav-logout" @onclick="HandleLogoutAsync">Logga ut</button>
            }
            else
            {
                <NavLink href="/">Logga in</NavLink>
                <NavLink href="/register">Registrera</NavLink>
            }
        </div>
    </nav>

    <!-- SIDINNEHÅLL -->
    <main class="content px-4">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ett oväntat fel inträffade.
    <a href="." class="reload">Ladda om</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private record AuthData(string Token, string Email, string UserName);
    private const string StorageKey = "cyberquiz_auth";

    protected override void OnInitialized()
    {
        AuthStateService.OnChange += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            var result = await ProtectedLocalStorage.GetAsync<AuthData>(StorageKey);
            if (result.Success && result.Value is not null)
                AuthStateService.SetUser(result.Value.Token, result.Value.Email, result.Value.UserName);
        }
        catch { }
    }

    private async void OnAuthStateChanged()
    {
        try
        {
            if (AuthStateService.IsAuthenticated)
                await ProtectedLocalStorage.SetAsync(StorageKey, new AuthData(AuthStateService.Token!, AuthStateService.Email!, AuthStateService.UserName!));
            else
                await ProtectedLocalStorage.DeleteAsync(StorageKey);
        }
        catch { }

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogoutAsync()
    {
        if (AuthStateService.Token is not null)
            await AuthApiClient.LogoutAsync(AuthStateService.Token);

        AuthStateService.ClearUser();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateService.OnChange -= OnAuthStateChanged;
    }
}