<div class="quiz-card" @onclick="HandleClick" style="cursor:@(OnClick.HasDelegate ? "pointer" : "default")">
    <div class="quiz-card-header">
        <h3>@Title</h3>
    </div>

    <div class="quiz-card-body">
        <p>@Description</p>
    </div>

    @if (!Unlocked || Completed)
    {
        <div class="quiz-card-tag">@(!Unlocked ? "Låst": Completed ? "Genomförd": "")</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public bool Unlocked { get; set; }
    [Parameter] public bool Completed { get; set;}
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate && Unlocked)
            await OnClick.InvokeAsync();
    }
}
